# ── App ──
ENVIRONMENT=development
PORT=8000
FRONTEND_URL=http://localhost:8000

# ── 資料主權：Railway PostgreSQL（SQLAlchemy DSN）──
DATABASE_URL=postgresql+psycopg2://orderai:orderai@localhost:5432/orderai

# ── Auth ──
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ── LINE 兩支 channel 完全分離（嚴禁共用變數名）──
# Messaging channel：webhook 驗簽 + reply/push
LINE_MESSAGING_CHANNEL_ID=
LINE_MESSAGING_CHANNEL_SECRET=
LINE_MESSAGING_ACCESS_TOKEN=
# Login channel：OAuth authorize + token 交換
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
LINE_LOGIN_CALLBACK_URL=http://localhost:8000/api/v1/auth/line/callback

# ── LLM Provider（可替換 openai/claude/ollama）──
LLM_PROVIDER=openai
LLM_API_KEY=your-openai-api-key
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ── AI 自動化（律八）──
AI_CONFIDENCE_THRESHOLD=0.7

# ── PR-2：Redis / Queue（情境一）──
REDIS_URL=redis://localhost:6379/0
QUEUE_BACKEND=redis
QUEUE_NAME=line_webhook

# ── PR-2：StallPay 金流橋接（情境四）──
STALLPAY_API_BASE=https://api.stallpay.merchcore.ai
STALLPAY_API_KEY=

# ── i18n ──
DEFAULT_LANG=zh-TW
