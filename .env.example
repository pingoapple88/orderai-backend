# ── App ──
ENVIRONMENT=development
PORT=8000
FRONTEND_URL=http://localhost:8000

# ── 資料主權：Railway PostgreSQL（SQLAlchemy DSN）──
DATABASE_URL=postgresql+psycopg2://orderai:orderai@localhost:5432/orderai

# ── Auth ──
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ── LINE OAuth（律一：Adapter）──
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# ── LLM Provider（可替換 openai/claude/ollama）──
LLM_PROVIDER=openai
LLM_API_KEY=your-openai-api-key
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ── AI 自動化（律八）──
AI_CONFIDENCE_THRESHOLD=0.7
